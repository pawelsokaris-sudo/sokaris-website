---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'SOKARIS — Polskie oprogramowanie biznesowe', description = 'Fakturowanie, księgowość, rozwój. Twórcy Faktura-NT i Sapio. Polskie oprogramowanie dla firm od 1996 roku.' } = Astro.props;
---
<!doctype html>
<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0a0a1a" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #07070f;
      --bg-card: rgba(255,255,255,0.03);
      --bg-card-hover: rgba(255,255,255,0.06);
      --border: rgba(255,255,255,0.08);
      --border-hover: rgba(139,92,246,0.3);
      --text: #e4e4ef;
      --text-dim: #8b8ba0;
      --text-bright: #ffffff;
      --accent: #a78bfa;
      --accent-bright: #c4b5fd;
      --gradient-start: #7c3aed;
      --gradient-end: #06b6d4;
      --section-gap: clamp(4rem, 8vw, 7rem);
      --wrap: min(1140px, 90vw);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* === Ambient glow === */
    body::before {
      content: '';
      position: fixed;
      top: -40%; left: -20%;
      width: 80vw; height: 80vw;
      background: radial-gradient(circle, rgba(124,58,237,0.08) 0%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -30%; right: -10%;
      width: 60vw; height: 60vw;
      background: radial-gradient(circle, rgba(6,182,212,0.06) 0%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }

    a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--accent-bright); }

    .wrap { width: var(--wrap); margin: 0 auto; }

    /* === Header === */
    .site-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1rem 0;
      background: rgba(7,7,15,0.7);
      backdrop-filter: blur(20px) saturate(1.6);
      border-bottom: 1px solid var(--border);
      transition: background 0.3s;
    }
    .header-inner {
      width: var(--wrap); margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-size: 1.15rem; font-weight: 700; letter-spacing: 0.08em;
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo span { font-weight: 400; opacity: 0.5; -webkit-text-fill-color: var(--text-dim); }
    .nav { display: flex; gap: 1.8rem; align-items: center; }
    .nav a {
      color: var(--text-dim); font-size: 0.85rem; font-weight: 500;
      letter-spacing: 0.02em; transition: color 0.2s;
    }
    .nav a:hover { color: var(--text-bright); }
    .nav .nav-cta {
      padding: 0.45rem 1.1rem; border-radius: 8px;
      background: rgba(167,139,250,0.12); color: var(--accent);
      border: 1px solid rgba(167,139,250,0.2);
      font-size: 0.82rem; font-weight: 600;
      transition: all 0.25s;
    }
    .nav .nav-cta:hover {
      background: rgba(167,139,250,0.2);
      border-color: rgba(167,139,250,0.4);
      transform: translateY(-1px);
    }

    /* Mobile nav */
    .nav-toggle { display: none; background: none; border: none; color: var(--text); cursor: pointer; padding: 0.5rem; }
    @media (max-width: 768px) {
      .nav { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0;
        background: rgba(7,7,15,0.95); backdrop-filter: blur(20px); padding: 1.5rem; gap: 1.2rem;
        border-bottom: 1px solid var(--border); }
      .nav.open { display: flex; }
      .nav-toggle { display: block; }
    }

    /* === Sections === */
    section { padding: var(--section-gap) 0; }
    .section-label {
      display: inline-block; font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 0.8rem;
      padding: 0.3rem 0.8rem; border-radius: 100px;
      background: rgba(167,139,250,0.08); border: 1px solid rgba(167,139,250,0.15);
    }
    .section-title {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700;
      color: var(--text-bright); line-height: 1.2; margin-bottom: 0.6rem;
    }
    .section-desc {
      font-size: 1rem; color: var(--text-dim); max-width: 560px;
      line-height: 1.7; margin-bottom: 2.5rem;
    }

    /* === Cards === */
    .card-grid {
      display: grid; gap: 1.2rem;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
    .card {
      position: relative; padding: 1.8rem; border-radius: 16px;
      background: var(--bg-card); border: 1px solid var(--border);
      transition: all 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
      overflow: hidden;
    }
    .card::before {
      content: ''; position: absolute; inset: 0; border-radius: 16px;
      background: linear-gradient(135deg, rgba(124,58,237,0.06) 0%, transparent 50%);
      opacity: 0; transition: opacity 0.35s;
    }
    .card:hover {
      border-color: var(--border-hover);
      background: var(--bg-card-hover);
      transform: translateY(-3px);
    }
    .card:hover::before { opacity: 1; }
    .card-icon {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; margin-bottom: 1.2rem;
      background: rgba(167,139,250,0.1); border: 1px solid rgba(167,139,250,0.15);
    }
    .card h3 {
      font-size: 1.1rem; font-weight: 600; color: var(--text-bright);
      margin-bottom: 0.5rem;
    }
    .card p { font-size: 0.88rem; color: var(--text-dim); line-height: 1.65; }
    .card-link {
      display: inline-flex; align-items: center; gap: 0.4rem;
      margin-top: 1rem; font-size: 0.82rem; font-weight: 600;
      color: var(--accent); transition: gap 0.2s;
    }
    .card:hover .card-link { gap: 0.7rem; }

    /* === Buttons === */
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.6rem; border-radius: 10px;
      font-size: 0.9rem; font-weight: 600; cursor: pointer;
      transition: all 0.25s; border: none; text-decoration: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--gradient-start), #9333ea);
      color: #fff; box-shadow: 0 4px 20px rgba(124,58,237,0.3);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 30px rgba(124,58,237,0.45);
      color: #fff;
    }
    .btn-ghost {
      background: rgba(255,255,255,0.04); color: var(--text);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.15);
      color: var(--text-bright);
    }

    /* === Footer === */
    .site-footer {
      padding: 3rem 0 2rem;
      border-top: 1px solid var(--border);
      color: var(--text-dim); font-size: 0.8rem;
    }
    .footer-inner {
      width: var(--wrap); margin: 0 auto;
      display: flex; flex-wrap: wrap; justify-content: space-between;
      align-items: flex-start; gap: 2rem;
    }
    .footer-brand .logo { margin-bottom: 0.5rem; }
    .footer-brand p { max-width: 280px; font-size: 0.78rem; line-height: 1.6; }
    .footer-links { display: flex; gap: 3rem; }
    .footer-col h4 {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text); margin-bottom: 0.8rem;
    }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 0.4rem; }
    .footer-col a { color: var(--text-dim); font-size: 0.8rem; }
    .footer-col a:hover { color: var(--accent); }
    .footer-bottom {
      width: var(--wrap); margin: 2rem auto 0;
      padding-top: 1.5rem; border-top: 1px solid var(--border);
      display: flex; flex-wrap: wrap; justify-content: space-between;
      font-size: 0.75rem; color: rgba(139,138,160,0.6);
    }

    /* === Animations === */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .anim { opacity: 0; animation: fadeUp 0.7s ease forwards; }
    .anim-d1 { animation-delay: 0.1s; }
    .anim-d2 { animation-delay: 0.2s; }
    .anim-d3 { animation-delay: 0.3s; }
    .anim-d4 { animation-delay: 0.4s; }
    .anim-d5 { animation-delay: 0.5s; }

    /* Scroll-triggered via IntersectionObserver */
    .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.25,0.46,0.45,0.94); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">SOKARIS <span>· software</span></a>
      <button class="nav-toggle" aria-label="Menu" onclick="document.querySelector('.nav').classList.toggle('open')">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <nav class="nav">
        <a href="#produkty">Produkty</a>
        <a href="#serwis">Serwis</a>
        <a href="#rozwoj">R&D</a>
        <a href="#kontakt">Kontakt</a>
        <a href="https://bok.faktura-nt.pl" target="_blank" rel="noopener" class="nav-cta">Panel klienta</a>
      </nav>
    </div>
  </header>

  <slot />

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="logo" style="margin-bottom:0.6rem">SOKARIS</div>
        <p>Polskie oprogramowanie biznesowe od 1996 roku. Fakturowanie, księgowość i platforma serwisowa dla tysięcy firm w&nbsp;całej Polsce.</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Produkty</h4>
          <ul>
            <li><a href="https://faktura-nt.pl" target="_blank" rel="noopener">Faktura-NT</a></li>
            <li><a href="https://sapio.pl" target="_blank" rel="noopener">Sapio</a></li>
            <li><a href="https://www.oprogramowanie.e-xtra.pl/index.php?ids=130&grupy=57&pztps=0" target="_blank" rel="noopener">Sklep</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Serwis</h4>
          <ul>
            <li><a href="https://bok.faktura-nt.pl" target="_blank" rel="noopener">Panel klienta BOK</a></li>
            <li><a href="https://bok.faktura-nt.pl/aktualizacje" target="_blank" rel="noopener">Aktualizacje</a></li>
            <li><a href="https://assistant.faktura-nt.pl/zglos" target="_blank" rel="noopener">Zgłoś problem</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Firma</h4>
          <ul>
            <li><a href="/polityka-prywatnosci">Polityka prywatności</a></li>
            <li><a href="#kontakt">Kontakt</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 1996–2026 SOKARIS · NIP: 576-105-16-34</span>
      <span>Sokaris Oprogramowanie · ul.&nbsp;Błękitna&nbsp;3 · 46-300&nbsp;Olesno</span>
    </div>
  </footer>

  <script>
    // Scroll reveal
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }});
    }, { threshold: 0.1,  rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  </script>
</body>
</html>
