---
import Base from '../layouts/Base.astro';
---
<Base>
    <!-- ===== HERO ===== -->
    <section class="hero">
        <div class="wrap">
            <div class="hero-badge">Polskie oprogramowanie biznesowe · od 1996</div>
            <h1 class="hero-title">
                Fakturowanie, księgowość, <span class="grad">rozwój</span>.
            </h1>
            <p class="hero-lead">
                Tworzymy oprogramowanie dla polskich firm od prawie trzech dekad.
                Faktura-NT, Sapio oraz własna platforma event-sourced pod operacje
                przyszłości — wszystko pod jednym dachem.
            </p>
            <div class="hero-cta">
                <a href="#produkty" class="btn btn-primary">Zobacz produkty</a>
                <a href="https://bok.faktura-nt.pl" target="_blank" rel="noopener" class="btn btn-ghost">
                    Jestem klientem — do BOK →
                </a>
            </div>
        </div>
    </section>

    <!-- ===== PRODUKTY ===== -->
    <section id="produkty" class="section">
        <div class="wrap">
            <div class="section-head">
                <span class="eyebrow">Produkty</span>
                <h2>Rozwiązania które sprzedajemy</h2>
                <p class="section-lead">
                    Dwie dojrzałe aplikacje z tysiącami aktywnych klientów.
                    Wspierane, aktualizowane, gotowe na KSeF.
                </p>
            </div>

            <div class="cards cards-2">
                <a href="https://faktura-nt.pl" target="_blank" rel="noopener" class="card">
                    <div class="card-icon" aria-hidden="true">📊</div>
                    <h3>Faktura-NT</h3>
                    <p>
                        Program do fakturowania dla firm i księgowych.
                        Pełna obsługa KSeF, JPK, import/eksport, multi-stanowiskowy.
                        Sprawdzony przez 30&nbsp;000+ polskich firm.
                    </p>
                    <div class="card-cta">faktura-nt.pl →</div>
                </a>

                <a href="https://sapio.pl" target="_blank" rel="noopener" class="card">
                    <div class="card-icon" aria-hidden="true">💼</div>
                    <h3>Sapio</h3>
                    <p>
                        System księgowo-handlowy dla firm wielooddziałowych.
                        Księgowość, magazyn, CRM, integracje z KSeF
                        i bankami — wszystko w jednym miejscu.
                    </p>
                    <div class="card-cta">sapio.pl →</div>
                </a>
            </div>
        </div>
    </section>

    <!-- ===== SERWIS ===== -->
    <section id="serwis" class="section section-alt">
        <div class="wrap">
            <div class="section-head">
                <span class="eyebrow">Serwis</span>
                <h2>Jeden kanał wsparcia</h2>
                <p class="section-lead">
                    Biuro Obsługi Klienta prowadzimy w jednym miejscu —
                    bez przerzucania między systemami, bez czekania na infolinii.
                </p>
            </div>

            <div class="service-hub">
                <div class="service-hub-main">
                    <h3>bok.faktura-nt.pl</h3>
                    <p>
                        Wszystko czego potrzebujesz jako nasz klient:
                    </p>
                    <ul class="service-features">
                        <li>📋 <strong>Historia zmian</strong> — pełny changelog każdej wersji</li>
                        <li>🤖 <strong>AI asystent</strong> — sprawdź czy Twój problem został już rozwiązany</li>
                        <li>📝 <strong>Zgłoszenia serwisowe</strong> — z potwierdzeniem i śledzeniem</li>
                        <li>📞 <strong>Infolinia</strong> — 22 38 956 38 (pon-pt, godziny biurowe)</li>
                    </ul>
                    <div style="margin-top:24px; display:flex; gap:12px; flex-wrap:wrap;">
                        <a href="https://bok.faktura-nt.pl" target="_blank" rel="noopener" class="btn btn-primary">
                            Przejdź do BOK
                        </a>
                        <a href="tel:+48223895638" class="btn btn-ghost">
                            📞 22 38 956 38
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== BADANIA I ROZWÓJ ===== -->
    <section id="badania" class="section">
        <div class="wrap">
            <div class="section-head">
                <span class="eyebrow">Badania i rozwój</span>
                <h2>Budujemy własną platformę</h2>
                <p class="section-lead">
                    Nie kupujemy cudzych narzędzi — tworzymy własny framework
                    event-sourced dla aplikacji biznesowych przyszłości.
                </p>
            </div>

            <div class="cards cards-3">
                <div class="card card-rnd">
                    <div class="card-icon" aria-hidden="true">🧩</div>
                    <h3>ActProof.io</h3>
                    <p>
                        Platforma event-sourced — fundament pod nowoczesne aplikacje
                        biznesowe. Każda zmiana jako zdarzenie, weryfikowalna historia,
                        deterministyczne rekonstrukcje stanu.
                    </p>
                    <div class="card-cta">actproof.io →</div>
                </div>

                <div class="card card-rnd">
                    <div class="card-icon" aria-hidden="true">⚙️</div>
                    <h3>ActProof-OS</h3>
                    <p>
                        ERP dla operacji — zarządzanie czasem pracy i jakością,
                        a w kolejnych fazach produkcja i monitoring urządzeń.
                        Wszystkie warstwy na jednym event-sourced silniku.
                    </p>
                    <div class="card-cta">W rozwoju</div>
                </div>

                <div class="card card-rnd">
                    <div class="card-icon" aria-hidden="true">🔌</div>
                    <h3>ACP</h3>
                    <p>
                        Agent Context Protocol — otwarty standard onboardingu
                        agentów AI do projektów programistycznych.
                        Open-source, udostępniamy społeczności.
                    </p>
                    <div class="card-cta">acp.actproof.io →</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== KONTAKT ===== -->
    <section id="kontakt" class="section section-alt">
        <div class="wrap">
            <div class="section-head" style="text-align:center">
                <span class="eyebrow">Kontakt</span>
                <h2>Jak się z nami skontaktować</h2>
            </div>

            <div class="contact-grid">
                <div class="contact-item">
                    <div class="contact-icon">🎧</div>
                    <h4>Jesteś naszym klientem?</h4>
                    <p>
                        Skorzystaj z <a href="https://bok.faktura-nt.pl" target="_blank" rel="noopener">Biura Obsługi</a>
                        — tam znajdziesz AI asystenta, zgłoszenia i historię zmian.
                    </p>
                </div>

                <div class="contact-item">
                    <div class="contact-icon">📞</div>
                    <h4>Telefon</h4>
                    <p>
                        <a href="tel:+48223895638">22 38 956 38</a><br/>
                        <small>pon-pt, godziny biurowe</small>
                    </p>
                </div>

                <div class="contact-item">
                    <div class="contact-icon">✉️</div>
                    <h4>E-mail</h4>
                    <p>
                        <a href="mailto:bok@sokaris.pl">bok@sokaris.pl</a><br/>
                        <small>odpowiadamy w dzień roboczy</small>
                    </p>
                </div>
            </div>
        </div>
    </section>

</Base>

<style>
    /* ===== HERO ===== */
    .hero {
        padding: 72px 0 88px;
        background: linear-gradient(180deg, #f8fafc 0%, #fafbfc 100%);
        border-bottom: 1px solid var(--border);
    }
    .hero-badge {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(139, 92, 246, 0.08);
        border: 1px solid rgba(139, 92, 246, 0.2);
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        color: #7c3aed;
        letter-spacing: .3px;
        margin-bottom: 20px;
    }
    .hero-title {
        font-size: clamp(36px, 5vw, 56px);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -.02em;
        max-width: 820px;
        margin-bottom: 20px;
    }
    .grad {
        background: var(--brand-gradient);
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .hero-lead {
        font-size: 18px;
        color: var(--text-muted);
        max-width: 680px;
        margin-bottom: 32px;
    }
    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

    /* ===== BUTTONS ===== */
    .btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 22px;
        border-radius: 8px;
        font-weight: 600; font-size: 15px;
        transition: all .15s ease;
        cursor: pointer;
    }
    .btn-primary {
        background: var(--brand-gradient);
        color: #fff !important;
        box-shadow: var(--shadow-md);
    }
    .btn-primary:hover { opacity: 0.95; transform: translateY(-1px); }
    .btn-ghost {
        background: #fff;
        color: var(--text) !important;
        border: 1px solid var(--border);
    }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent) !important; }

    /* ===== SECTIONS ===== */
    .section { padding: 80px 0; }
    .section-alt { background: var(--bg-alt); }
    .section-head { max-width: 680px; margin: 0 auto 56px; text-align: center; }
    .eyebrow {
        display: inline-block;
        font-size: 12px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1.5px;
        color: #8b5cf6;
        margin-bottom: 10px;
    }
    .section h2 {
        font-size: clamp(28px, 4vw, 40px);
        font-weight: 800;
        letter-spacing: -.01em;
        margin-bottom: 12px;
    }
    .section-lead {
        font-size: 17px;
        color: var(--text-muted);
    }

    /* ===== CARDS ===== */
    .cards { display: grid; gap: 24px; }
    .cards-2 { grid-template-columns: repeat(2, 1fr); }
    .cards-3 { grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 900px) {
        .cards-2, .cards-3 { grid-template-columns: 1fr; }
    }

    .card {
        display: block;
        background: var(--bg-alt);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 28px;
        color: var(--text) !important;
        transition: all .15s ease;
    }
    .card:hover {
        border-color: #c7d2fe;
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }
    .card-icon { font-size: 32px; margin-bottom: 16px; }
    .card h3 { font-size: 22px; font-weight: 700; margin-bottom: 10px; }
    .card p { color: var(--text-muted); font-size: 15px; }
    .card-cta {
        margin-top: 16px;
        color: var(--accent);
        font-weight: 600; font-size: 14px;
    }
    .card-rnd {
        background: linear-gradient(180deg, #fafbff 0%, #ffffff 100%);
    }

    /* ===== SERVICE HUB ===== */
    .service-hub-main {
        max-width: 780px; margin: 0 auto;
        background: var(--bg-alt);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 40px;
        box-shadow: var(--shadow-sm);
    }
    .service-hub-main h3 {
        font-size: 20px;
        font-family: ui-monospace, "SF Mono", Consolas, monospace;
        background: var(--brand-gradient);
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 16px;
    }
    .service-features { list-style: none; margin: 20px 0 0; }
    .service-features li {
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
        font-size: 15px;
    }
    .service-features li:last-child { border: 0; }

    /* ===== CONTACT ===== */
    .contact-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        max-width: 860px;
        margin: 0 auto;
    }
    @media (max-width: 720px) {
        .contact-grid { grid-template-columns: 1fr; }
    }
    .contact-item {
        text-align: center;
        background: var(--bg-alt);
        padding: 32px 24px;
        border-radius: 12px;
        border: 1px solid var(--border);
    }
    .contact-icon { font-size: 28px; margin-bottom: 12px; }
    .contact-item h4 { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
    .contact-item p { font-size: 14px; color: var(--text-muted); }
    .contact-item small { font-size: 12px; color: var(--text-soft); }
</style>
